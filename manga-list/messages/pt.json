  "HowToUseApi": {
    "title": "Como usar a API",
    "updatedAt": "Última atualização: 13 de março de 2026",
    "intro": "Guia final para integração de parceiros com foco em operação real, sem copiar código e com troubleshooting objetivo.",
    "baseUrlLabel": "Base URL atual da API neste frontend",
    "baseUrlNote": "Em produção, use a URL oficial da API. Os endpoints abaixo são relativos a essa base.",
    "rolesTitle": "Quem participa",
    "flowTitle": "Fluxo final do parceiro (sem copiar código)",
    "roles": {
      "partner": {
        "title": "Site parceiro (CLIENTE)",
        "body": "Orquestra inscrição, troca de código por token e envio de sync a partir do backend do parceiro."
      },
      "user": {
        "title": "Usuário final",
        "body": "Gera código temporário no Manga Tracker e compartilha com o parceiro."
      },
      "platform": {
        "title": "Manga Tracker (automático)",
        "body": "Valida domínio, credenciais, escopo, domínio permitido e regras de idempotência/sync."
      }
    },
    "steps": {
      "application": {
        "title": "1) Envie a inscrição pública",
        "body": "Cadastre o parceiro e guarde o id da inscrição para acompanhamento.",
        "endpoint": "POST /integrations/public/apply",
        "notes": {
          "1": "Endpoint público com rate limit e proteção anti-abuso.",
          "2": "O envio não ativa a integração automaticamente."
        }
      },
      "domainVerification": {
        "title": "2) Verifique posse do domínio",
        "body": "Publique a prova de domínio e execute a verificação antes da aprovação.",
        "endpoint": "POST /integrations/public/apply/{applicationId}/verify-domain",
        "notes": {
          "1": "DNS TXT é o caminho recomendado; arquivo .well-known é fallback.",
          "2": "Aprovação fica bloqueada até status VERIFIED."
        }
      },
      "applicationStatus": {
        "title": "3) Consulte status quando necessário",
        "body": "Use o applicationId para polling de progresso e próxima ação.",
        "endpoint": "GET /integrations/public/apply/{applicationId}/status"
      },
      "approval": {
        "title": "4) Aguarde aprovação",
        "body": "Após aprovação, as credenciais (partnerSlug e clientSecret) são enviadas por e-mail."
      },
      "userConnectCode": {
        "title": "5) Usuário gera código de conexão",
        "body": "O usuário gera código temporário no Manga Tracker para vincular a conta ao parceiro."
      },
      "exchange": {
        "title": "6) Troque código por token no backend do parceiro",
        "body": "Use o endpoint de exchange com credenciais de parceiro e valide domínio de origem.",
        "endpoint": "POST /integrations/connect/exchange",
        "notes": {
          "1": "Rotação: secret ativo e secret anterior são aceitos durante a janela de transição.",
          "2": "Após expiração da janela, apenas o secret ativo autentica."
        }
      },
      "sync": {
        "title": "7) Envie sync de progresso",
        "body": "Envie eventos com idempotency key para retries seguros e resultado determinístico.",
        "endpoint": "POST /integrations/sync",
        "notes": {
          "1": "Outcomes: created, updated ou noop.",
          "2": "Health check opcional: GET /integrations/connection/status."
        }
      },
      "webhooks": {
        "title": "8) Configure webhooks de eventos",
        "body": "Cadastre endpoint por parceiro para receber eventos assinados e monitorar entregas/retries/DLQ.",
        "endpoint": "POST/GET /integrations/admin/partners/{partnerId}/webhooks",
        "notes": {
          "1": "Assinatura HMAC SHA-256 em timestamp.body; valide antes de processar.",
          "2": "Em falhas temporárias, a plataforma faz retry com backoff + jitter; no limite, evento vai para DLQ.",
          "3": "Faça deduplicação do consumidor por x-mangalist-event-id."
        }
      }
    },
    "security": {
      "title": "Checklist de segurança",
      "items": {
        "1": "Armazene clientSecret somente no backend.",
        "2": "Use allowlist de domínio e envie sourceDomain.",
        "3": "Use x-idempotency-key em todo retry.",
        "4": "Rotacione secrets periodicamente com janela de transição.",
        "5": "Use HTTPS fim a fim em produção."
      }
    },
    "limits": {
      "title": "Comportamento operacional",
      "items": {
        "1": "Scope exigido no MVP: manga:write.",
        "2": "chapter menor/igual ao atual retorna noop.",
        "3": "Access token de integração expira em 30 dias.",
        "4": "Rate limits e validações retornam erros claros por endpoint."
      }
    },
    "troubleshooting": {
      "title": "Erros comuns e troubleshooting",
      "items": {
        "1": "401 Missing partner credentials: clientSecret ausente para parceiro não público.",
        "2": "401 Invalid partner credentials: secret inválido ou janela do secret anterior expirada.",
        "3": "401 Invalid or expired connect code: gere novo código no Manga Tracker.",
        "4": "401 Connect code domain mismatch: alinhe sourceDomain no start e no exchange.",
        "5": "403 Missing manga:write scope: revise escopo da conexão/token.",
        "6": "403 Source domain is not allowed for partner: ajuste allowedDomains no admin.",
        "7": "429 Too many requests: respeite Retry-After e use backoff com jitter.",
        "8": "Sync em noop: comportamento esperado quando capítulo não avançou."
      }
    },
    "examples": {
      "title": "Exemplos ponta-a-ponta",
      "items": {
        "1": "Novo vínculo: start -> exchange -> sync(created).",
        "2": "Progresso contínuo: sync(updated) com capítulo maior.",
        "3": "Retry seguro: mesmo evento + mesma idempotency key mantêm resultado sem duplicidade.",
        "4": "Rotação sem downtime: exchange aceita secret anterior na janela e migra para o novo."
      }
    }
  },
