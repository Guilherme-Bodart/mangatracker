# Backend production environment example
NODE_ENV="production"
PORT=3001

# Database
DATABASE_URL="postgresql://user:password@host:5432/mangatrack?sslmode=require"

# JWT
JWT_SECRET="replace-with-a-strong-random-secret"
JWT_EXPIRES_IN="7d"

# OAuth (Google)
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"
GOOGLE_CALLBACK_URL="https://api.your-domain.com/auth/google/callback"

# Frontend
FRONTEND_URL="https://your-frontend-domain.com"
FRONTEND_URLS="https://your-frontend-domain.com"

# Cookies / reverse proxy
COOKIE_SECURE="true"
COOKIE_SAMESITE="lax"
COOKIE_DOMAIN=""
TRUST_PROXY="1"

# Security flags
PASSWORD_RESET_DEV_RESPONSE="false"
# Feature flag: keep false on free plan (set true for paid GIF uploads only)
ALLOW_ANIMATED_IMAGES="false"

# External APIs
EXTERNAL_API_TIMEOUT_MS=10000
EXTERNAL_API_RETRIES=2

# SMTP
MAIL_PROVIDER="smtp"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="noreply@your-domain.com"
SMTP_PASS="replace-with-smtp-secret"
SMTP_FROM="Manga Tracker <noreply@your-domain.com>"
SMTP_SECURE="false"

# Redis (recommended in production)
# Preferred format (works well with hosted Redis like Upstash):
REDIS_URL="rediss://default:password@host:6379"
REDIS_HOST="redis"
REDIS_PORT=6379
