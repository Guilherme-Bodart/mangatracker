# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/mangatrack"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# JWT
JWT_SECRET="replace-with-a-strong-random-secret"
JWT_EXPIRES_IN="7d"

# Frontend URLs
FRONTEND_URL="http://localhost:3000"
FRONTEND_URLS="http://localhost:3000"

# Environment/Cookies
NODE_ENV="development"
COOKIE_SECURE="false"
COOKIE_SAMESITE="lax"
# COOKIE_DOMAIN=""
TRUST_PROXY=""

# External APIs
EXTERNAL_API_TIMEOUT_MS=10000
EXTERNAL_API_RETRIES=2

# Password reset response (dev only)
PASSWORD_RESET_DEV_RESPONSE="false"

# Mail provider: "smtp" or "log"
MAIL_PROVIDER="log"
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Manga Tracker <no-reply@mangatracker.local>"
SMTP_SECURE="false"

# Redis (optional, for distributed cache/rate-limit)
REDIS_HOST="localhost"
REDIS_PORT=6379

# Backend port
PORT=3001
