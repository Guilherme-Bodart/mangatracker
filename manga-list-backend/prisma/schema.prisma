// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MangaStatus {
  READING
  COMPLETED
  PLAN_TO_READ
  DROPPED
}

enum IntegrationPartnerApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DomainVerificationStatus {
  PENDING
  VERIFIED
  FAILED
}

enum IntegrationPartnerSecretVersion {
  ACTIVE
  PREVIOUS
}

enum IntegrationWebhookDeliveryStatus {
  DELIVERED
  RETRY
  DLQ
}

model User {
  id            String        @id @default(uuid())
  username      String        @unique
  email         String        @unique
  password      String?       // Optional for OAuth users
  tokenVersion  Int           @default(0) // Invalidate all sessions when incremented
  googleId      String?       @unique // Google's unique user ID
  provider      String?       @default("local") // "local" or "google"
  avatarUrl     String?       // Profile picture URL
  bannerUrl     String?       // Profile banner/cover image URL
  allowNsfw     Boolean       @default(false) // Allow NSFW/adult content
  userMangas    UserManga[]
  partnerConnections UserPartnerConnection[]
  externalMangaMaps ExternalMangaMap[]
  syncEvents    SyncEventLog[]
  announcementsCreated Announcement[] @relation("AnnouncementCreator")
  announcementReads AnnouncementRead[]
  likesGiven    ProfileLike[] @relation("ProfileLikesGiven")
  likesReceived ProfileLike[] @relation("ProfileLikesReceived")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Manga {
  id            String      @id @default(uuid())
  malId         Int         @unique // MyAnimeList ID from Jikan
  anilistId     Int?        @unique // AniList ID (optional, for multi-provider mapping)
  title         String
  coverImage    String?
  author        String?
  genres        String[]    // Array of genre names
  totalChapters Int?
  description   String?     @db.Text // Synopsis
  descriptionPt String?     @db.Text // Portuguese Synopsis
  publicationStatus String? // "Publishing", "Finished", etc.
  lastChapter   String?     // Latest chapter release (e.g. "1032")
  lastCheckedAt DateTime?   // Last time we checked for updates
  userMangas    UserManga[]
  externalMangaMaps ExternalMangaMap[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model UserManga {
  id             String      @id @default(uuid())
  userId         String
  mangaId        String
  status         MangaStatus
  rating         Float?      // 0.0 to 5.0 (half stars allowed)
  currentChapter Int?        // Track reading progress
  notes          String?     @db.Text // User's private notes
  isFavorite     Boolean     @default(false)
  
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  manga          Manga       @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([userId, mangaId]) // User can only have one entry per manga
}

model ProfileLike {
  id          String   @id @default(uuid())
  likerId     String
  likedUserId String
  createdAt   DateTime @default(now())

  liker       User     @relation("ProfileLikesGiven", fields: [likerId], references: [id], onDelete: Cascade)
  likedUser   User     @relation("ProfileLikesReceived", fields: [likedUserId], references: [id], onDelete: Cascade)

  @@unique([likerId, likedUserId])
  @@index([likedUserId])
}

model IntegrationPartner {
  id               String                  @id @default(uuid())
  slug             String                  @unique
  name             String
  clientSecretHash String
  previousClientSecretHash String?
  previousClientSecretExpiresAt DateTime?
  allowedDomains   String[]                @default([])
  isActive         Boolean                 @default(true)
  connections      UserPartnerConnection[]
  externalMangaMaps ExternalMangaMap[]
  syncEvents       SyncEventLog[]
  secretUsageLogs  IntegrationSecretUsageLog[]
  webhookEndpoints IntegrationWebhookEndpoint[]
  webhookEvents    IntegrationWebhookEventLog[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
}

model UserPartnerConnection {
  id         String             @id @default(uuid())
  userId     String
  partnerId  String
  isActive   Boolean            @default(true)
  scopes     String[]           @default([])
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  partner    IntegrationPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([userId, partnerId])
  @@index([partnerId])
}

model ExternalMangaMap {
  id             String             @id @default(uuid())
  userId         String
  partnerId      String
  externalMangaId String
  mangaId        String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  partner        IntegrationPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  manga          Manga              @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([userId, partnerId, externalMangaId])
  @@index([userId, mangaId])
  @@index([partnerId])
}

model SyncEventLog {
  id              String             @id @default(uuid())
  userId          String
  partnerId       String
  externalMangaId String
  chapter         Int?
  outcome         String
  details         Json?
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  partner         IntegrationPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  createdAt       DateTime           @default(now())

  @@index([partnerId, createdAt])
  @@index([userId, createdAt])
  @@index([userId, partnerId, externalMangaId])
}

model IntegrationPartnerApplication {
  id               String                            @id @default(uuid())
  name             String
  requestedSlug    String
  contactEmail     String
  siteUrl          String
  allowedDomains   String[]                          @default([])
  useCase          String?                           @db.Text
  verificationDomain String?
  domainVerificationToken String?
  domainVerificationStatus DomainVerificationStatus  @default(PENDING)
  domainVerificationError String?                    @db.Text
  domainVerificationLastCheckedAt DateTime?
  domainVerifiedAt DateTime?
  status           IntegrationPartnerApplicationStatus @default(PENDING)
  reviewReason     String?                           @db.Text
  approvedPartnerId String?
  reviewedByEmail  String?
  reviewedAt       DateTime?
  createdAt        DateTime                          @default(now())
  updatedAt        DateTime                          @updatedAt

  @@index([status, createdAt])
  @@index([domainVerificationStatus, createdAt])
  @@index([requestedSlug])
  @@index([contactEmail, createdAt])
}

model IntegrationSecretUsageLog {
  id            String                          @id @default(uuid())
  partnerId     String
  secretVersion IntegrationPartnerSecretVersion
  sourceDomain  String?
  usedAt        DateTime                        @default(now())
  partner       IntegrationPartner              @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, usedAt])
  @@index([partnerId, secretVersion, usedAt])
}

model IntegrationWebhookEndpoint {
  id            String                         @id @default(uuid())
  partnerId     String
  url           String
  signingSecret String
  isActive      Boolean                        @default(true)
  partner       IntegrationPartner             @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  deliveries    IntegrationWebhookDeliveryLog[]
  createdAt     DateTime                       @default(now())
  updatedAt     DateTime                       @updatedAt

  @@unique([partnerId, url])
  @@index([partnerId, isActive])
}

model IntegrationWebhookEventLog {
  id         String                         @id @default(uuid())
  partnerId  String
  eventType  String
  payload    Json
  partner    IntegrationPartner             @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  deliveries IntegrationWebhookDeliveryLog[]
  createdAt  DateTime                       @default(now())

  @@index([partnerId, createdAt])
  @@index([eventType, createdAt])
}

model IntegrationWebhookDeliveryLog {
  id             String                           @id @default(uuid())
  eventId        String
  endpointId     String
  attempt        Int
  status         IntegrationWebhookDeliveryStatus
  responseStatus Int?
  errorMessage   String?
  nextRetryAt    DateTime?
  deliveredAt    DateTime?
  event          IntegrationWebhookEventLog       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  endpoint       IntegrationWebhookEndpoint       @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  createdAt      DateTime                         @default(now())

  @@index([endpointId, createdAt])
  @@index([eventId, createdAt])
  @@index([status, nextRetryAt])
}

model Announcement {
  id              String             @id @default(uuid())
  title           String?
  message         String             @db.Text
  titlePt         String?
  titleEn         String?
  messagePt       String?            @db.Text
  messageEn       String?            @db.Text
  isActive        Boolean            @default(true)
  createdByUserId String?
  createdBy       User?              @relation("AnnouncementCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  reads           AnnouncementRead[]
  createdAt       DateTime           @default(now())
  removedAt       DateTime?

  @@index([isActive, createdAt])
}

model AnnouncementRead {
  id             String       @id @default(uuid())
  announcementId String
  userId         String
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId, readAt])
}
