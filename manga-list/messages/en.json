  "HowToUseApi": {
    "title": "How to use API",
    "updatedAt": "Last updated: March 13, 2026",
    "intro": "Final guide for partner integration focused on real operations, without copy-paste code and with practical troubleshooting.",
    "baseUrlLabel": "Current API base URL in this frontend",
    "baseUrlNote": "In production, use the official API URL. Endpoints below are relative to that base.",
    "rolesTitle": "Who is involved",
    "flowTitle": "Final partner flow (without copy-paste code)",
    "roles": {
      "partner": {
        "title": "Partner site (CLIENT)",
        "body": "Orchestrates application, code exchange for token, and sync delivery from partner backend."
      },
      "user": {
        "title": "End user",
        "body": "Generates a short-lived code in Manga Tracker and shares it with the partner."
      },
      "platform": {
        "title": "Manga Tracker (automatic)",
        "body": "Validates domain, credentials, scopes, allowed domains, and idempotency/sync rules."
      }
    },
    "steps": {
      "application": {
        "title": "1) Submit public application",
        "body": "Register the partner and store the application id for tracking.",
        "endpoint": "POST /integrations/public/apply",
        "notes": {
          "1": "Public endpoint with rate limits and anti-abuse protections.",
          "2": "Submitting does not activate integration automatically."
        }
      },
      "domainVerification": {
        "title": "2) Verify domain ownership",
        "body": "Publish domain proof and run verification before approval.",
        "endpoint": "POST /integrations/public/apply/{applicationId}/verify-domain",
        "notes": {
          "1": "DNS TXT is recommended; .well-known file is fallback.",
          "2": "Approval is blocked until status becomes VERIFIED."
        }
      },
      "applicationStatus": {
        "title": "3) Check status when needed",
        "body": "Use applicationId for progress polling and next action.",
        "endpoint": "GET /integrations/public/apply/{applicationId}/status"
      },
      "approval": {
        "title": "4) Wait for approval",
        "body": "After approval, credentials (partnerSlug and clientSecret) are sent by email."
      },
      "userConnectCode": {
        "title": "5) User generates connect code",
        "body": "User generates a short-lived code in Manga Tracker to link account to partner."
      },
      "exchange": {
        "title": "6) Exchange code for token in partner backend",
        "body": "Use exchange endpoint with partner credentials and source domain validation.",
        "endpoint": "POST /integrations/connect/exchange",
        "notes": {
          "1": "Rotation: active and previous secret are accepted during transition window.",
          "2": "After transition window expires, only active secret authenticates."
        }
      },
      "sync": {
        "title": "7) Send progress sync",
        "body": "Send events with idempotency key for safe retries and deterministic outcomes.",
        "endpoint": "POST /integrations/sync",
        "notes": {
          "1": "Outcomes: created, updated, or noop.",
          "2": "Optional health check: GET /integrations/connection/status."
        }
      },
      "webhooks": {
        "title": "8) Configure event webhooks",
        "body": "Register endpoint per partner to receive signed events and monitor deliveries/retries/DLQ.",
        "endpoint": "POST/GET /integrations/admin/partners/{partnerId}/webhooks",
        "notes": {
          "1": "HMAC SHA-256 signature over timestamp.body; verify before processing.",
          "2": "On transient failures, platform retries with backoff + jitter; at max attempts, event goes to DLQ.",
          "3": "Deduplicate on consumer side by x-mangalist-event-id."
        }
      }
    },
    "security": {
      "title": "Security checklist",
      "items": {
        "1": "Store clientSecret only on backend.",
        "2": "Use domain allowlist and send sourceDomain.",
        "3": "Use x-idempotency-key on every retry.",
        "4": "Rotate secrets periodically with transition windows.",
        "5": "Use end-to-end HTTPS in production."
      }
    },
    "limits": {
      "title": "Operational behavior",
      "items": {
        "1": "Required scope in MVP: manga:write.",
        "2": "Incoming chapter <= current chapter returns noop.",
        "3": "Integration access token expires in 30 days.",
        "4": "Rate limits and validations return clear endpoint-specific errors."
      }
    },
    "troubleshooting": {
      "title": "Common errors and troubleshooting",
      "items": {
        "1": "401 Missing partner credentials: clientSecret missing for non-public partner.",
        "2": "401 Invalid partner credentials: invalid secret or expired previous-secret window.",
        "3": "401 Invalid or expired connect code: generate a new code in Manga Tracker.",
        "4": "401 Connect code domain mismatch: align sourceDomain in start and exchange.",
        "5": "403 Missing manga:write scope: review connection/token scope.",
        "6": "403 Source domain is not allowed for partner: adjust allowedDomains in admin.",
        "7": "429 Too many requests: honor Retry-After and use backoff with jitter.",
        "8": "Sync noop: expected when chapter did not move forward."
      }
    },
    "examples": {
      "title": "End-to-end examples",
      "items": {
        "1": "New link: start -> exchange -> sync(created).",
        "2": "Continuous progress: sync(updated) with higher chapter.",
        "3": "Safe retry: same event + same idempotency key keeps result without duplication.",
        "4": "Zero-downtime rotation: exchange accepts previous secret in-window and migrates to new one."
      }
    }
  },
